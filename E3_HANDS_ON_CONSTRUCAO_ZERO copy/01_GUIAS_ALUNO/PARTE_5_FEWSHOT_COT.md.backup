## 📊 CÓDIGO FINAL COMPLETO

Seu `agente_v2_0.py` final deve ter:

```python
# agente_v2_0.py
# VERSÃO FINAL COMPLETA

from langchain_ollama import OllamaLLM
from langchain.agents import initialize_agent, AgentType
from tools_basicas import (
    contar_armas_marca,
    contar_armas_calibre,
    contar_armas_tipo,
    contar_armas_combinado
)

# ============================================================
# VALIDAÇÃO DE SEGURANÇA
# ============================================================

def validar_input(texto: str):
    """Valida input contra ataques"""
    if len(texto) > 500:
        raise ValueError("Query muito longa (máx 500 caracteres)")
    if len(texto) < 3:
        raise ValueError("Query muito curta (mín 3 caracteres)")
    
    caracteres_perigosos = [";", "--", "DROP", "DELETE", "INSERT"]
    for char in caracteres_perigosos:
        if char in texto.upper():
            raise ValueError(f"Caractere perigoso: {char}")
    
    return True

def perguntar_agente_seguro(pergunta: str):
    """Wrapper seguro"""
    try:
        validar_input(pergunta)
        resposta = agente.invoke({"input": pergunta})
        return resposta["output"]
    except ValueError as e:
        return f"❌ ERRO DE SEGURANÇA: {e}"
    except Exception as e:
        return f"❌ ERRO: {e}"

# ============================================================
# CONFIGURAÇÃO DO AGENTE
# ============================================================

llm = OllamaLLM(model="llama3", temperature=0)

system_message = """
Você é investigador PCDF especialista em SINARM.

=== EXEMPLOS (Few-Shot) ===

Pergunta: "O que é BO de furto?"
Resposta: "BO de furto é Boletim de Ocorrência tipo=FURTO no SINARM."

Pergunta: "Calibre .38?"
Resposta: "Calibre .38 TPC é munição de revólver 9mm."

=== CHAIN-OF-THOUGHT ===

Sempre siga:

PASSO 1 - ANÁLISE: Tipo de pergunta? Dados necessários?
PASSO 2 - BUSCA: Tool e parâmetros
PASSO 3 - RESULTADO: Valores obtidos
PASSO 4 - RESPOSTA: Conclusão + Fonte: SINARM

=== INSTRUÇÕES ===
- Linguagem técnica PCDF
- Sempre cite fonte
- Mostre raciocínio
"""

agente = initialize_agent(
    tools=[contar_armas_marca, contar_armas_calibre,
           contar_armas_tipo, contar_armas_combinado],
    llm=llm,
    agent=AgentType.ZERO_SHOT_REACT_DESCRIPTION,
    verbose=True,
    agent_kwargs={"system_message": system_message}
)

# ============================================================
# INTERFACE
# ============================================================

if __name__ == "__main__":
    print("\n" + "="*60)
    print("🤖 AGENTE SINARM v2.0")
    print("="*60 + "\n")
    
    while True:
        pergunta = input("\n❓ Sua pergunta (ou 'sair'): ")
        
        if pergunta.lower() == 'sair':
            print("\n👋 Até logo!")
            break
        
        resposta = perguntar_agente_seguro(pergunta)
        print(f"\n💬 {resposta}\n")
        print("-"*60)
```

