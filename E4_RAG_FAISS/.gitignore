# ============================================================================
# .GITIGNORE - E4_RAG_FAISS
# ============================================================================
# Arquivos e diretórios que NÃO devem ser versionados no Git

# ────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO SENSÍVEL (NUNCA COMPARTILHAR!)
# ────────────────────────────────────────────────────────────────────────────
.env
*.env
!.env.example

# ────────────────────────────────────────────────────────────────────────────
# AMBIENTE VIRTUAL PYTHON
# ────────────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
*.pyc
__pycache__/
*.py[cod]
*$py.class

# ────────────────────────────────────────────────────────────────────────────
# DADOS GERADOS / CACHE
# ────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.faiss
*.pkl
*.pickle
embeddings/
indices/
*.log

# ────────────────────────────────────────────────────────────────────────────
# IDEs / EDITORES
# ────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ────────────────────────────────────────────────────────────────────────────
# JUPYTER NOTEBOOK
# ────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ────────────────────────────────────────────────────────────────────────────
# BUILDS / DISTRIBUIÇÃO
# ────────────────────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ────────────────────────────────────────────────────────────────────────────
# TESTES
# ────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover

# ────────────────────────────────────────────────────────────────────────────
# TEMPORÁRIOS
# ────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
