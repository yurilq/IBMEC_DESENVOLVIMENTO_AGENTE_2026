# ============================================================================
# .ENV.EXAMPLE - Configuração de Ambiente para E4_RAG_FAISS
# ============================================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env:
#    cp .env.example .env  (Linux/Mac)
#    copy .env.example .env  (Windows)
#
# 2. Preencha com suas credenciais reais
# 3. NUNCA compartilhe o arquivo .env real (ele está no .gitignore)
#
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# TIPO DE LLM: "ollama" (local) ou "openrouter" (API)
# ────────────────────────────────────────────────────────────────────────────
LLM_TYPE=openrouter

# ────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO OPENROUTER (API)
# ────────────────────────────────────────────────────────────────────────────
# Obtenha sua API key em: https://openrouter.ai/keys
# Formato: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-SUA_CHAVE_AQUI

# Modelo a usar (recomendado: meta-llama/llama-3-8b-instruct)
# Outros modelos disponíveis em: https://openrouter.ai/docs#models
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# ────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO OLLAMA (LOCAL) - Apenas se LLM_TYPE=ollama
# ────────────────────────────────────────────────────────────────────────────
# Modelo local (ex: llama3, mistral, phi3)
# Baixe modelos com: ollama pull llama3
OLLAMA_MODEL=llama3

# URL do servidor Ollama (padrão: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Timeout em segundos para requisições ao Ollama
OLLAMA_TIMEOUT=120

# ────────────────────────────────────────────────────────────────────────────
# PARÂMETROS GERAIS DO LLM
# ────────────────────────────────────────────────────────────────────────────
# Temperatura (0 = determinístico, 1 = criativo)
# Recomendado: 0 para precisão em análise de dados
TEMPERATURE=0

# Tamanho do contexto em tokens
# Recomendado: 4096 para a maioria dos casos
NUM_CTX=4096

# ============================================================================
# NOTAS:
# ============================================================================
# 
# OPENROUTER vs OLLAMA:
# - OpenRouter: Requer API key, pago por uso, mais rápido, sem instalação
# - Ollama: 100% local, gratuito, requer GPU/CPU potente, privacidade total
#
# MODELOS RECOMENDADOS:
# - OpenRouter: meta-llama/llama-3-8b-instruct (barato, rápido)
# - Ollama: llama3 (8B), mistral (7B), phi3 (3.8B)
#
# CUSTOS ESTIMADOS (OpenRouter):
# - Llama 3 8B: ~$0.10 por 1M tokens input, ~$0.20 por 1M tokens output
# - Para este projeto: ~$0.01 - $0.05 por sessão de testes
#
# TROUBLESHOOTING:
# - Se OPENROUTER_API_KEY não funcionar, verifique formato: sk-or-v1-...
# - Se Ollama não conectar, inicie com: ollama serve
# - Para testar configuração, execute: python scripts_agente/config_llm.py
#
# ============================================================================
